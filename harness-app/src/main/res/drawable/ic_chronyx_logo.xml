<?xml version="1.0" encoding="utf-8"?>
<!-- CHRONYX mark: a time-sync reticle. Concentric ring + axis ticks + center lock dot, in phosphor.
     Operational Materialism: minimal, geometric, single accent. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- outer ring -->
    <path
        android:strokeColor="#2EE6A6"
        android:strokeWidth="3"
        android:fillColor="#00000000"
        android:pathData="M54,20 a34,34 0 1,0 0.001,0 Z" />

    <!-- inner ring -->
    <path
        android:strokeColor="#2EE6A6"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M54,34 a20,20 0 1,0 0.001,0 Z" />

    <!-- axis ticks (4 crosshair arms) -->
    <path android:strokeColor="#2EE6A6" android:strokeWidth="3" android:pathData="M54,8 L54,24" />
    <path android:strokeColor="#2EE6A6" android:strokeWidth="3" android:pathData="M54,84 L54,100" />
    <path android:strokeColor="#2EE6A6" android:strokeWidth="3" android:pathData="M8,54 L24,54" />
    <path android:strokeColor="#2EE6A6" android:strokeWidth="3" android:pathData="M84,54 L100,54" />

    <!-- center lock dot -->
    <path
        android:fillColor="#2EE6A6"
        android:pathData="M54,48 a6,6 0 1,0 0.001,0 Z" />
</vector>
