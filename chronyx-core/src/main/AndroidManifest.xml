<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        chronyx-core is a pure capture library. It declares the permissions it needs to function
        but does NOT request them; the host app (harness-app or a perception head) owns the runtime
        permission flow and FGS-type declarations. Background location is intentionally NOT declared
        here — capture runs in a foreground service owned by the host.
    -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

</manifest>
